        let speed=length(stateB[i].velocity);let impact=smoothstep(eventC0.x,max(eventC0.x+1.0,eventC0.z),speed);let speedCount=max(0.0,floor(eventA0.y*(1.0+impact*eventC0.y)+0.5));
