{
  "name": "@hooksjam/gl-game-lab-engine",
  "version": "0.0.0",
  "description": "GLGameLab engine composition and game-authoring facade",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc --build --force tsconfig.json",
