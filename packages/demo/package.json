{
  "name": "@hooksjam/gl-game-lab-demo",
  "private": true,
  "version": "0.0.0",
  "description": "Browser demo and parity host for GLGameLab",
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @hooksjam/gl-game-lab-engine build && pnpm --filter @hooksjam/gl-game-lab-simulations particle:compile",
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hooksjam/gl-game-lab-core": "workspace:*",
    "@hooksjam/gl-game-lab-engine": "workspace:*",
    "@hooksjam/gl-game-lab-games": "workspace:*",
    "@hooksjam/gl-game-lab-react": "workspace:*",
    "@hooksjam/gl-game-lab-render-webgl2": "workspace:*",
    "@hooksjam/gl-game-lab-render-webgpu": "workspace:*",
    "@hooksjam/gl-game-lab-simulations": "workspace:*",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.400.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  }
}
