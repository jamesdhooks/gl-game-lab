{
  "name": "@hooksjam/gl-game-lab-react",
  "version": "0.0.0",
  "description": "React host components for GLGameLab",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc --build --force tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "clean": "tsc --build --clean tsconfig.json"
  },
  "dependencies": {
    "@hooksjam/gl-game-lab-core": "workspace:*",
    "@hooksjam/gl-game-lab-engine": "workspace:*",
    "@hooksjam/gl-game-lab-platform-web": "workspace:*",
    "@hooksjam/gl-game-lab-render-webgl2": "workspace:*",
    "@hooksjam/gl-game-lab-tools": "workspace:*",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.400.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0"
  },
  "license": "UNLICENSED"
}
