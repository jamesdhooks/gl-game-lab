{
  "name": "@hooksjam/gl-game-lab-simulations",
  "version": "0.0.0",
  "description": "GPU-first simulation content for GLGameLab",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "particle:compile": "tsx scripts/compile-particle-effects.mjs",
    "build": "pnpm particle:compile && tsc --build --force tsconfig.json && node scripts/copy-assets.mjs",
    "typecheck": "pnpm particle:compile && tsc --noEmit --project tsconfig.json",
    "test": "pnpm particle:compile && vitest run --passWithNoTests",
    "clean": "tsc --build --clean tsconfig.json"
  },
  "dependencies": {
    "@hooksjam/gl-game-lab-core": "workspace:*",
    "@hooksjam/gl-game-lab-engine": "workspace:*",
    "@hooksjam/gl-game-lab-physics-2d": "workspace:*"
  },
  "license": "UNLICENSED"
}
